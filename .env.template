# ============================================================
# CTF Agent 配置模板
# 复制此文件为 .env 并填入你的配置
# ============================================================

# ============================================================
# 1. API 密钥配置（必填）
# ============================================================
SILICONFLOW_API_KEY=your-siliconflow-api-key-here

# 可选：如果使用其他 API 提供商
# OPENAI_API_KEY=sk-xxx
# DASHSCOPE_API_KEY=ms-xxx


# ============================================================
# 2. LLM 基础配置
# ============================================================
LLM_PROVIDER=openai
OPENAI_BASE_URL=https://api.siliconflow.cn/v1
MODEL_NAME=Pro/zai-org/GLM-5


# ============================================================
# 3. 三大专家模型配置
# ============================================================

# CTF 战略专家
CTF_API_KEY=your-siliconflow-api-key-here
CTF_BASE_URL=https://api.siliconflow.cn/v1
CTF_MODEL=Pro/zai-org/GLM-5

# Python 编程专家
PYTHON_API_KEY=your-siliconflow-api-key-here
PYTHON_BASE_URL=https://api.siliconflow.cn/v1
PYTHON_MODEL=Pro/moonshotai/Kimi-K2.5

# 安全渗透专家
SECURITY_API_KEY=your-siliconflow-api-key-here
SECURITY_BASE_URL=https://api.siliconflow.cn/v1
SECURITY_MODEL=Pro/zai-org/GLM-5


# ============================================================
# 4. RAG 知识库配置
# ============================================================
EMBEDDING_API_KEY=your-siliconflow-api-key-here
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5

CHROMA_DB_DIR=data/chroma_db
KNOWLEDGE_BASE_DIR=data/knowledge_base


# ============================================================
# 5. SSH 远程执行配置（可选）
# ============================================================
SSH_HOST=192.168.1.100
SSH_PORT=22
SSH_USER=kali
SSH_PASSWORD=kali
# SSH_KEY_PATH=/path/to/private/key


# ============================================================
# 快速配置指南
# ============================================================
#
# 步骤 1: 获取硅基流动 API Key
#   访问: https://siliconflow.cn
#   注册并获取 API Key
#
# 步骤 2: 填入 API Key
#   将所有 "your-siliconflow-api-key-here" 替换为你的 API Key
#
# 步骤 3: 配置 SSH（如果需要远程 Kali）
#   修改 SSH_HOST, SSH_USER, SSH_PASSWORD
#
# 步骤 4: 运行测试
#   python test_llm.py  # 测试 LLM 连接
#   python test_embedding.py  # 测试 Embedding
#
# ============================================================
